{
    "storageSlots": 24,              // The amount of storage slots in the dark world inventory
    "enableRecruits": false,          // Enable recruit messages and menu
    "recruitsProgressSpaces": false,  // Whether the recruits progress in the menu will have spaces between the amounts
    "smallSaveMenu": false,          // Single-file save menu with no storage/recruits options
    "lessEquipments": false,         // Reduces the amount of available weapons and armor slots in the inventory

    "partyActions": true,            // Whether X-Actions appear in spell menu by default

    "growStronger": false,            // Stat increases after defeating an enemy with violence
    "growStrongerChara": null,   // Character to prioritize for the "X became stronger" message

    "susieStyle": 2,                 // Susie chapter style
    "ralseiStyle": 2,                // Ralsei chapter style

    "oldTensionBar": false,          // Syle of TP bar
    "oldUIPositions": false,         // Old positions of various UI elements
    "oldGameOver": false,            // The game over screen used in chapter 1
    "oldRudeBuster": true,           // Old Rude Buster damage calculation and effect
    "oldPacify": false,              // Removes the animation from the Pacify spell
    "oldDualHealFormula": false,     // Old Dual Heal amount calculation

    "speechBubble": "cyber",         // Default enemy speech bubble style

    "enemyAuras": true,              // Red glow around overworld enemies

    "mercyMessages": false,           // "+X%" mercy messages
    "mercyBar": false,                // Mercy bar next to hp bar in enemy select
    "enemyBarPercentages": true,     // HP / Mercy bar percentages
    "pacifyGlow": false,             // Pacify (and other spells) glow when enemies are TIRED
    "tiredMessages": false,          // Tired mercy messages
    "awakeMessages": false,          // Awake un-mercy messages

    "targetSystem": false,           // Whether the target system should be used or not
    "soulInvBetweenWaves": false,    // Whether the soul invulnerability will carry between waves in battles

    "darkCurrency": "Social Credit",  // Full currency name for the Dark World
    "darkCurrencyShort": "SC",       // Short currency name for the Dark World

    "lightCurrency": "Social Credit",        // Full currency name for the Light World
    "lightCurrencyShort": "SC",       // Short currency name for the Light World
    "tpName": "PP",                  // Name of Tension Points in battles

    "prioritySpareableText": false,  // Whether enemies' spareable text should be prioritized over their tired / low-health text

    "pushBlockInputLock": true,      // Whether to lock the player's input when pushing a block
    "keepTensionAfterBattle": false, // Whether TP should be kept after battle instead of reset
    "overworldSpells": false,        // Whether spells should be usable in the overworld
    "damageUnderflowFix": true,      // When disabled, negative enemy damage heals the enemy and displays a negative damage number
    "darkCandyForm": "dark",         // Whether to use Dark Candy or Darker Candy
    "canTossLightWeapons": true      // Whether light world weapons can be thrown away
}